    "NSCameraUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A program running within c11mux would like to use your camera."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "c11mux 内で実行中のプログラムがカメラの使用を求めています。"
          }
        }
      }
    },
    "NSMicrophoneUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A program running within c11mux would like to use your microphone."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "c11mux 内で実行中のプログラムがマイクの使用を求めています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 c11mux 中运行的程序想要使用您的麦克风。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在 c11mux 中執行的程式想要使用您的麥克風。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "c11mux 내에서 실행 중인 프로그램이 마이크를 사용하려고 합니다."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein in c11mux ausgeführtes Programm möchte Ihr Mikrofon verwenden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un programa en ejecución dentro de c11mux desea usar tu micrófono."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un programme s'exécutant dans c11mux souhaite utiliser votre microphone."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un programma in esecuzione in c11mux desidera utilizzare il microfono."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Et program, der kører i c11mux, vil gerne bruge din mikrofon."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Program działający w c11mux chciałby użyć Twojego mikrofonu."
