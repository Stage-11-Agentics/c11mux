    "NSCameraUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A program running within c11 would like to use your camera."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "c11 内で実行中のプログラムがカメラの使用を求めています。"
          }
        }
      }
    },
    "NSMicrophoneUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A program running within c11 would like to use your microphone."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "c11 内で実行中のプログラムがマイクの使用を求めています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 c11 中运行的程序想要使用您的麦克风。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在 c11 中執行的程式想要使用您的麥克風。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "c11 내에서 실행 중인 프로그램이 마이크를 사용하려고 합니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Программа, запущенная в c11, хотела бы использовать ваш микрофон."
          }
        }
      }
    },
