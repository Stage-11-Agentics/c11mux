    "NSCameraUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A program running within c11 would like to use your camera."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "c11 内で実行中のプログラムがカメラの使用を求めています。"
          }
        }
      }
    },
    "NSMicrophoneUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A program running within c11 would like to use your microphone."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "c11 内で実行中のプログラムがマイクの使用を求めています。"
