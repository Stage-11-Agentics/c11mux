    "NSLocalNetworkUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A program running within c11 would like to discover devices on your local network."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
