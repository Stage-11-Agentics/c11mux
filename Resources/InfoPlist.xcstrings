        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "c11 내에서 실행 중인 프로그램이 마이크를 사용하려고 합니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Программа, запущенная в c11, хотела бы использовать ваш микрофон."
          }
        }
      }
    },
    "NSDownloadsFolderUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A program running within c11 would like to access files in your Downloads folder."
          }
