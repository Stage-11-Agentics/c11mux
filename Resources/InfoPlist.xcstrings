        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "c11 内で実行中のプログラムが、ダウンロードフォルダ内のファイルへのアクセスを求めています。"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Програма, запущена в c11, хоче отримати доступ до файлів у вашій теці «Завантаження»."
          }
