        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Программа, запущенная в c11mux, хотела бы использовать ваш микрофон."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Program koji se izvršava unutar c11mux želi koristiti vaš mikrofon."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يرغب برنامج يعمل داخل c11mux في استخدام الميكروفون."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Et program som kjører i c11mux ønsker å bruke mikrofonen din."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Um programa em execução no c11mux gostaria de usar seu microfone."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "โปรแกรมที่ทำงานภายใน c11mux ต้องการใช้ไมโครโฟนของคุณ"
